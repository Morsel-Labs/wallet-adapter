{
  "name": "@morsel-wallet/adapter",
  "version": "0.1.1",
  "type": "module",
  "description": "Wallet adapter for Morsel / Cookie Chain — core, React hooks, and UI",
  "scripts": {
    "build": "tsc && node scripts/fix-extensions.mjs && node scripts/copy-assets.mjs",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.87.6",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.87.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "typescript": "^5"
  },
  "keywords": [
    "wallet",
    "adapter",
    "morsel",
    "cookie",
    "chain",
    "solana",
    "svm",
    "react"
  ],
  "license": "MIT",
  "dependencies": {
    "@wallet-standard/app": "^1.1.0",
    "bs58": "^6.0.0",
    "eventemitter3": "^5.0.1",
    "qrcode": "^1.5.4",
    "tweetnacl": "^1.0.3"
  }
}
